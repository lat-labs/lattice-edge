# Core compute plane connection (through NGINX gateway)
LATTICE_RAY_ADDRESS=ray://l40.latticelab.ai:9443
LATTICE_RAY_NAMESPACE=lattice
LATTICE_CORE_API_URL=https://latticelab.ai:8000

# Ray auth token (provided by core node admin — openssl rand -hex 32)
RAY_AUTH_TOKEN=<token from core admin>

# Local settings
JUPYTER_PORT=8889